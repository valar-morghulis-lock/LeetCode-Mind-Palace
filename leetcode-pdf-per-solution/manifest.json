{
  "manifest_version": 3,
  "name": "LeetCode Mind Palace — PDF Export",
  "version": "2.0",
  "description": "Extracts LeetCode problems and exports a professional PDF. No backend required.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.leetcode.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
